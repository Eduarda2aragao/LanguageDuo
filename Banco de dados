#========================================================================================#

CREATE TABLE aula (
    id_aula INT AUTO_INCREMENT PRIMARY KEY,
    id_usuario INT,
    id_curso INT NOT NULL,
    id_duracao INT NOT NULL,
    data_aula DATE NOT NULL,
    hora_aula TIME NOT NULL,
    
    FOREIGN KEY (id_usuario) REFERENCES usuario(id),
    FOREIGN KEY (id_curso) REFERENCES curso(id_curso),
    FOREIGN KEY (id_duracao) REFERENCES duracao(id_duracao)
);

select * from aula;
drop table aula;

#========================================================================================#
                                    #JOIN#
                                    
                                  


SELECT 
    a.data_aula AS data,
    a.hora_aula AS hora,
    u.nome AS aluno,
    c.idioma AS curso,
    p.nome AS professor,
    d.descricao AS duracao
FROM 
    aula a
JOIN usuario u ON a.id_usuario = u.id
JOIN curso c ON a.id_curso = c.id_curso
JOIN professor p ON c.id_professor = p.id_professor
JOIN duracao d ON a.id_duracao = d.id_duracao
WHERE 
    a.data_aula >= CURDATE()
ORDER BY 
    a.data_aula, 
    a.hora_aula;
